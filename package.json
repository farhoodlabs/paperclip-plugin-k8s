{
  "name": "@farhoodlabs/paperclip-plugin-k8s",
  "version": "0.1.13",
  "description": "Kubernetes sandbox provider plugin for Paperclip environments",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "sandbox",
    "kubernetes",
    "k8s"
  ],
  "scripts": {
    "build": "rm -rf dist && node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.22.0"
  },
  "peerDependencies": {
    "@paperclipai/plugin-sdk": "*"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.427.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "esbuild": "^0.27.3",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
