{
  "name": "@farhoodlabs/paperclip-plugin-k8s",
  "version": "0.0.1",
  "description": "Kubernetes sandbox provider plugin for Paperclip environments",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "sandbox",
    "kubernetes",
    "k8s"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.22.0"
  },
  "peerDependencies": {
    "@paperclipai/plugin-sdk": "*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
